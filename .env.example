# Database Configuration (Local PostgreSQL)
# Default container URL from docker-compose.yml in this project root.
DATABASE_URL=postgresql://ikodi:ikodi_dev_password@localhost:5432/ikodi_db

# API Configuration
NODE_ENV=development
PORT=5173
API_PORT=3001
API_URL=http://localhost:3001
BASE_PATH=/

# Frontend Configuration
VITE_API_URL=http://localhost:3001

# Email Service (SendGrid)
# Get your API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@ikodi.local

# SMS Service (Twilio)
# Get credentials from https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Optional but recommended for sender branding:
# 1) Twilio Messaging Service SID (preferred for production)
TWILIO_MESSAGING_SERVICE_SID=
# 2) Alphanumeric sender ID where your country/carrier supports it (e.g. IKODI)
TWILIO_SENDER_ID=IKODI
# 3) Fallback Twilio phone number (E.164)
TWILIO_PHONE_NUMBER=+1234567890
# SMS text brand prefix (message starts with this label)
SMS_BRAND_NAME=IKODI

# Session Configuration
SESSION_SECRET=your_random_session_secret_here_change_in_production

# Security
# Required when NODE_ENV=production. Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:5173
# Keep disabled by default. Only enable for local demos.
ENABLE_DEV_AUTH_BYPASS=false

# Testing
TEST_DATABASE_URL=postgresql://ikodi:ikodi_dev_password@localhost:5432/ikodi_test
